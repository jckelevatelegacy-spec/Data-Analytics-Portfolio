            <column caption='Metric' datatype='real' name='[Calculation_1040143985274886]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Revenue&quot; THEN [Calculation_1040143620845568]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;Order Count&quot; THEN [Calculation_1040143621439491]&#13;&#10;ELSEIF [Parameters].[Parameter 1] = &quot;Average Order Value&quot; THEN [Calculation_1040143621058561]&#13;&#10;END' />

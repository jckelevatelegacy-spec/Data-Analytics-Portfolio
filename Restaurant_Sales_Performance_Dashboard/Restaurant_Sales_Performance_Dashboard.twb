      <column caption='Revenue Growth %' datatype='real' name='[Calculation_1040143621644292]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([revenue_usd]) - LOOKUP(SUM([revenue_usd]),-1))&#13;&#10;/&#13;&#10;ABS(LOOKUP(SUM([revenue_usd]),-1))'>

      <column caption='Average Order Value' datatype='real' name='[Calculation_1040143621058561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue_usd]) / COUNT([r_id])' />
      </column>
      <column caption='Revenue Per Restaurant' datatype='real' name='[Calculation_1040143621246978]' role='measure' type='quantitative'>
